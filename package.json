{
  "name": "pinline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.ts",
    "dev:api": "node --watch src/index.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "test": "node --test test/*.test.ts",
    "e2e": "node test/e2e.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
